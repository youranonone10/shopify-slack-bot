# ── Slack ────────────────────────────────────────────────
# Get from: api.slack.com > Your App > OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-token-here

# Get from: Slack > Right-click channel > Copy link (last part of URL)
SLACK_CHANNEL_ID=C0123456789

# Get from: Slack > Right-click supplier user > Copy member ID
SUPPLIER_SLACK_USER_ID=U0123456789

# ── Shopify Webhook Secrets ──────────────────────────────
# Get from: Shopify Admin > Settings > Notifications > Webhooks
# Each store has its own secret
WEBHOOK_SECRET_STORE1=your_secret_for_store1
WEBHOOK_SECRET_STORE2=your_secret_for_store2
WEBHOOK_SECRET_STORE3=your_secret_for_store3

# ── Database ─────────────────────────────────────────────
# Optional: change where the SQLite file is stored
# DB_PATH=./data/requests.db
